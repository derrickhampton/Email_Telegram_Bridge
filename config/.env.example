# Environment variables for email_telegram_bridge
# Copy this file to config/.env and fill in real values.
# Do not commit config/.env to source control.

# Email account secret used by accounts.json -> secret_env
EMAIL_ACCOUNT_SECRET='your_email_account_secret'

# Telegram bot settings
TELEGRAM_BOT_TOKEN=''
TELEGRAM_CHAT_ID=''

# Optional reply feature settings
# EMAIL_REPLY_APPROVAL_TTL_MINUTES='60'
# EMAIL_REPLY_ALLOWED_ACCOUNTS='imap'
# EMAIL_REPLY_ALLOWED_DOMAINS='example.com,example.com'
# EMAIL_REPLY_BLOCKED_LOCALPART_PREFIXES='noreply,no-reply,donotreply,mailer-daemon'
# EMAIL_REPLY_BLOCK_BULK='true'
